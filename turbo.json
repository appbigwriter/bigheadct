{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "build/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": ["coverage/**", "test-results/**"]
    },
    "@bigheadct/api#test": {
      "outputs": []
    },
    "@bigheadct/worker#test": {
      "outputs": []
    },
    "@bigheadct/contracts#test": {
      "outputs": []
    },
    "@bigheadct/ui#test": {
      "outputs": []
    }
  }
}
