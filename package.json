{
  "name": "bigheadct",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.26.2",
  "engines": {
    "node": "24.11.1",
    "pnpm": "10.26.2"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter @bigheadct/web test:e2e",
    "contracts:generate": "pnpm --filter @bigheadct/contracts generate",
    "contracts:check": "uv run --project apps/api python scripts/sync_openapi.py --check",
    "sprint2:handoff-check": "node scripts/verify-sprint2-handoff.mjs",
    "sprint2:access-check": "uv run --project apps/api python scripts/verify-access-handoff.py",
    "frontend:fixture-guard": "node scripts/check-no-direct-fixture-imports.mjs",
    "frontend:ui-guard": "node scripts/verify-ui-primitives.mjs",
    "db:start": "pnpm exec supabase start && docker compose up -d redis otel-collector",
    "db:stop": "docker compose down && pnpm exec supabase stop",
    "db:reset": "pnpm exec supabase db reset",
    "db:test": "pnpm exec supabase test db",
    "db:lint": "pnpm exec supabase db lint --local --schema public,private,storage --level error --fail-on error",
    "db:advisors": "pnpm exec supabase db advisors --local --type all --level warn --fail-on error",
    "db:verify": "pnpm db:reset --local --yes && pnpm db:test && pnpm db:lint && pnpm db:advisors",
    "test:integration:supabase": "node scripts/run-supabase-integration.mjs",
    "test:integration:outbox": "node scripts/run-outbox-smoke.mjs",
    "test:e2e:real": "node scripts/run-real-e2e.mjs",
    "test:e2e:deployed": "node scripts/run-deployed-e2e.mjs",
    "db:restore-test": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test-local-restore.ps1",
    "db:performance-test": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test-local-performance.ps1",
    "audit": "pnpm audit --prod && uv run --project apps/api pip-audit && uv run --project apps/worker pip-audit",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@next/eslint-plugin-next": "15.5.20",
    "@playwright/test": "^1.55.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.34.0",
    "jsdom": "^26.1.0",
    "openapi-typescript": "^7.9.1",
    "prettier": "^3.6.2",
    "supabase": "^2.39.2",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
