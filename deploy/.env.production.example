APP_ENV=production
APP_URL=https://head.fbr.news
API_URL=https://apibig.fbr.news
CORS_ORIGINS=https://head.fbr.news
LOG_LEVEL=INFO

WEB_DOMAIN=head.fbr.news
API_DOMAIN=apibig.fbr.news
ACME_EMAIL=<operations-email>

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=<publishable-key>
SUPABASE_SECRET_KEY=<secret-key>
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<publishable-key>
SUPABASE_PROJECT_REF=<project-ref>
SUPABASE_ACCESS_TOKEN=<personal-access-token>
SUPABASE_DB_PASSWORD=<database-password>
SUPABASE_AUTH_SITE_URL=https://head.fbr.news
SUPABASE_AUTH_REDIRECT_URLS=https://head.fbr.news/auth/callback
SUPABASE_AUTH_SMTP_CONFIGURED=true

DATABASE_URL=postgresql://<app-role>:<password>@<pooler>:6543/postgres?sslmode=require
DATABASE_SERVICE_URL=postgresql://<service-role>:<password>@<pooler>:6543/postgres?sslmode=require
DIRECT_DATABASE_URL=postgresql://postgres:<password>@<direct-host>:5432/postgres?sslmode=require
STORAGE_BUCKET=artifacts
SIGNED_URL_TTL_SECONDS=900

REDIS_PASSWORD=<generate-with-openssl-rand-hex-32>
QUEUE_NAME=bighead:jobs
JOB_LEASE_SECONDS=300
MALWARE_SCANNER_URL=clamd://clamav:3310
MALWARE_SCANNER_API_KEY=

LLM_PROVIDER_DEFAULT=<openai-anthropic-or-google>
LLM_PROVIDER_FALLBACK=<different-provider>
LLM_MODEL_DEFAULT=<exact-model-name>
LLM_MODEL_FALLBACK=<exact-model-name>
LLM_TIMEOUT_SECONDS=60
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENAI_API_KEY=

# Opcional: executor HTTP próprio. Vazio usa o executor multi-LLM interno.
RUN_PROVIDER_URL=
RUN_PROVIDER_API_KEY=
RUN_PROVIDER_TIMEOUT_SECONDS=60
# Opcional: integração com CRM externo. O CRM interno não depende disto.
CRM_PROVIDER_ENDPOINTS={}

SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=bighead-api
WORKER_OTEL_SERVICE_NAME=bighead-worker

ENCRYPTION_KEY=<generate-32-or-more-random-characters>
WEBHOOK_SIGNING_SECRET=<generate-with-openssl-rand-hex-32>
PORTAL_TOKEN_PEPPER=<generate-with-openssl-rand-hex-32>
