# Banco e storage.
DATABASE_URL=
DATABASE_SERVICE_URL=
DIRECT_DATABASE_URL=
STORAGE_BUCKET=bighead
MALWARE_SCANNER_URL=clamd://clamav:3310

# Redis e filas.
REDIS_URL=redis://default:Senha@tools_redis-bighead:6379
REDIS_HOST=tools_redis-bighead
REDIS_PASSWORD=
QUEUE_NAME=bighead:jobs
JOB_LEASE_SECONDS=300

# Autenticação e SMTP.
AUTH_GOOGLE_CLIENT_ID=OPTIONAL_UNTIL_PROVIDER_SELECTED
AUTH_GOOGLE_CLIENT_SECRET=OPTIONAL_UNTIL_PROVIDER_SELECTED
AUTH_MICROSOFT_CLIENT_ID=OPTIONAL_UNTIL_PROVIDER_SELECTED
AUTH_MICROSOFT_CLIENT_SECRET=OPTIONAL_UNTIL_PROVIDER_SELECTED

SMTP_HOST=mail.facebrasil.com
SMTP_PORT=465
SMTP_FROM=appsextou@facebrasil.com
SMTP_SECURE=true
SMTP_USERNAME=appsextou@facebrasil.com
SMTP_PASSWORD=

# LLM e integrações.
LLM_PROVIDER_DEFAULT=hermes
LLM_PROVIDER_FALLBACK=
LLM_MODEL_DEFAULT=hermes
LLM_MODEL_FALLBACK=gpt-4o-mini 
LLM_TIMEOUT_SECONDS=180
LLM_MONTHLY_BUDGET_CENTS=500000

EMBEDDING_MODEL=OPTIONAL_UNTIL_PROVIDER_SELECTED
EMBEDDING_DIMENSION=1536

OPENAI_API_KEY=
ANTHROPIC_API_KEY=OPTIONAL_UNTIL_PROVIDER_SELECTED
GOOGLE_GENAI_API_KEY=OPTIONAL_UNTIL_PROVIDER_SELECTED

HERMES_URL=https://hermes.fbr.news
HERMES_API_URL=https://hermes.fbr.news
HERMES_API_KEY=
HERMES_PROFILES_DIR=/opt/data/.hermes
HERMES_DEFAULT_MODEL=deepseek/deepseek-v4-pro
HERMES_TIMEOUT_SECONDS=60

ANYTHING_LLM_API_URL=https://rag.fbr.news/
ANYTHING_LLM_API_KEY=
ANYTHING_LLM_TIMEOUT_SECONDS=60
ANYTHING_LLM_STORAGE_DIR=/app/server/storage
ANYTHINGLLM_JWT_SECRET=
KNOWLEDGE_BACKEND=anythingllm
KNOWLEDGE_BACKEND_REQUIRED=true

# Integrações opcionais.
CRM_BASE_URL=OPTIONAL_UNTIL_PROVIDER_SELECTED
CRM_API_KEY=OPTIONAL_UNTIL_PROVIDER_SELECTED
ENRICHMENT_API_KEY=OPTIONAL_UNTIL_PROVIDER_SELECTED
EMAIL_PROVIDER_API_KEY=OPTIONAL_UNTIL_PROVIDER_SELECTED
SOCIAL_PUBLISHING_API_KEY=OPTIONAL_UNTIL_PROVIDER_SELECTED
WEBHOOK_SIGNING_SECRET=local_webhook_secret_123

# Observabilidade e criptografia.
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=bighead-platform
ENCRYPTION_KEY=
PORTAL_TOKEN_PEPPER=local_pepper_secret_123
SIGNED_URL_TTL_SECONDS=900

ACME_EMAIL=sergio@facebrasil.com

S3_PROTOCOL_ACCESS_KEY_ID=
S3_PROTOCOL_ACCESS_KEY_SECRET=
